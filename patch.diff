Patch: uvcvideo: add force_altsetting module parameter

Generated against torvalds/linux v6.8.

--- a/uvc_driver.c	2026-05-27 15:36:35.892402098 -0700
+++ b/uvc_driver.c	2026-05-27 15:35:59.800451060 -0700
@@ -35,6 +35,7 @@
 static unsigned int uvc_quirks_param = -1;
 unsigned int uvc_dbg_param;
 unsigned int uvc_timeout_param = UVC_CTRL_STREAMING_TIMEOUT;
+int uvc_force_altsetting_param = -1;
 
 /* ------------------------------------------------------------------------
  * Utility functions
@@ -2378,6 +2379,10 @@
 MODULE_PARM_DESC(trace, "Trace level bitmask");
 module_param_named(timeout, uvc_timeout_param, uint, 0644);
 MODULE_PARM_DESC(timeout, "Streaming control requests timeout");
+module_param_named(force_altsetting, uvc_force_altsetting_param, int, 0644);
+MODULE_PARM_DESC(force_altsetting,
+	"Force iso alternate setting N for all UVC streams (-1 = auto, default). "
+	"Use to constrain USB iso bandwidth when running many cameras on one bus.");
 
 /* ------------------------------------------------------------------------
  * Driver initialization and cleanup
--- a/uvc_video.c	2026-05-27 15:36:36.944400726 -0700
+++ b/uvc_video.c	2026-05-27 15:35:59.800451060 -0700
@@ -1967,6 +1967,36 @@
 			return -EIO;
 		}
 
+		/*
+		 * Force a specific alternate setting if the user requested it
+		 * via the force_altsetting module parameter. This is used to
+		 * constrain USB isochronous bandwidth when multiple cameras
+		 * share a single USB controller.
+		 */
+		if (uvc_force_altsetting_param >= 0) {
+			for (i = 0; i < intf->num_altsetting; ++i) {
+				struct usb_host_interface *alts;
+				struct usb_host_endpoint *forced_ep;
+
+				alts = &intf->altsetting[i];
+				if (alts->desc.bAlternateSetting !=
+					uvc_force_altsetting_param)
+					continue;
+				forced_ep = uvc_find_endpoint(alts,
+					stream->header.bEndpointAddress);
+				if (forced_ep == NULL)
+					break;
+				altsetting = alts->desc.bAlternateSetting;
+				best_ep = forced_ep;
+				best_psize = uvc_endpoint_max_bpi(
+					stream->dev->udev, forced_ep);
+				dev_info(&stream->dev->udev->dev,
+					"uvcvideo: forcing alt setting %u (%u B/frame)\n",
+					altsetting, best_psize);
+				break;
+			}
+		}
+
 		uvc_dbg(stream->dev, VIDEO,
 			"Selecting alternate setting %u (%u B/frame bandwidth)\n",
 			altsetting, best_psize);
--- a/uvcvideo.h	2026-05-27 15:36:37.340400211 -0700
